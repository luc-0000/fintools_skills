# ============================================================
# 环境变量配置示例文件
# 使用说明：复制此文件为 .env，并填入您的真实API密钥
# ============================================================

# 禁用Python字节码生成 (可选，用于开发环境)
# 作用：防止Python生成__pycache__目录，保持项目目录干净
PYTHONDONTWRITEBYTECODE=1


# ===== 金融数据 API 密钥 =====

# Tushare API Token (推荐，专业的中国金融数据源)
# 获取地址: https://tushare.pro/register?reg=128886
# 获取步骤：
# 1. 注册Tushare账号 -> 邮箱验证
# 2. 登录后进入个人中心 -> 获取Token
# 3. 复制Token（格式：xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx）
# 注意：免费用户有调用频率限制，建议升级积分获得更高权限
TUSHARE_TOKEN=your-tushare-token-here

# Mairui API Token (可选，麦蕊金融数据)
# 获取地址：联系麦蕊官方获取
# 注意：如果使用 Tushare，此项可不配置
MAIRUI_TOKEN=your-mairui-token-here
